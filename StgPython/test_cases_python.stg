emitTestCaseAsFunc(sFuncName, arrsVars, sModName, sTasName, sAmber, sEnc, bValueAssignment, sInitializeTcData, bStatic, sGenerateDatFile, arrsDummyInitStatementsNeededForStatementCoverage, sInitAmber) ::= <<
def <sFuncName>() -> None:
    from .<sModName>_auto_tcs import <sTasName>_<sEnc>enc_dec, <sTasName>_<sEnc>enc_dec_generic

    <arrsVars; separator="\n">

    <sInitializeTcData>

    _ = <sTasName>_<sEnc>enc_dec(tc_data, "<sFuncName>")
    _ = <sTasName>_<sEnc>enc_dec_generic(tc_data, "<sFuncName>_generic")

    <! Always empty - not generating: <sGenerateDatFile>!>
>>


